# ── Astronasamp configuration ────────────────────────────────
# Copy this file to ".env" and fill in your real Slack credentials.
#   cp .env.example .env

# Bot User OAuth Token (starts with xoxb-)
# Slack app → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-Level Token with connections:write scope (starts with xapp-)
# Slack app → Basic Information → App-Level Tokens
SLACK_APP_TOKEN=xapp-your-app-token

# ── Optional tuning ──────────────────────────────────────────
# Log verbosity: debug | info | warn | error   (default: info)
LOG_LEVEL=info

# Upstream HTTP timeout in milliseconds (default: 8000)
HTTP_TIMEOUT_MS=8000
